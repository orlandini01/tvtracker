DATABASE_URL=postgresql+psycopg2://tvtracker:tvtracker@localhost:5432/tvtracker
SECRET_KEY=changeme-generate-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_BASE_URL=https://api.themoviedb.org/3
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# Opcional: sem isso configurado, o link de "esqueci minha senha" só
# aparece no console do backend (modo dev) em vez de ser enviado por
# email de verdade. Pra usar Gmail: crie uma "senha de app" em
# https://myaccount.google.com/apppasswords (não use a senha normal da
# conta) e use smtp.gmail.com na porta 587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=TrackerTV <no-reply@trackertv.local>
FRONTEND_URL=http://localhost:5173

# De quantas em quantas horas o backend confere sozinho se saiu episódio
# novo de alguma série favoritada/acompanhada (dispara sino + email + push).
EPISODE_CHECK_INTERVAL_HOURS=6

# Opcional: sem isso configurado, notificação push do navegador não é
# enviada de verdade (só loga no console, modo dev). Gere seu próprio par
# de chaves com: python -m app.scripts.gen_vapid_keys
# NUNCA reaproveite um par de exemplo/de outro projeto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@trackertv.local
